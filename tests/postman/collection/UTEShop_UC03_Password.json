		{
			"name": "2. Đổi mật khẩu (Logged in)",
			"item": [
				{
					"name": "Thành công (Change Success)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{auth_token}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"oldPassword\": \"Customer@123\",\n    \"newPassword\": \"Changed@123!\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/users/profile/change-password",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"users",
								"profile",
								"change-password"
							]
						}
					},
					"response": []
				},
				{
					"name": "Lỗi - Sai mật khẩu cũ",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{auth_token}}",
									"type": "string"
								}
							]
						},
